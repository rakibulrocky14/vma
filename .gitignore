# ─── Dependencies ────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ────────────────────────────────
/.next/
/out/
/build

# ─── Testing ─────────────────────────────────────────────
/coverage

# ─── Environment variables ───────────────────────────────
# Keep .env.example (safe template) but ignore real env files
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ─── Database ────────────────────────────────────────────
# Never commit the local SQLite DB or its journal files
*.db
*.db-journal
*.db-shm
*.db-wal

# ─── Prisma generated client ─────────────────────────────
/src/generated/

# ─── OS / Editor ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ─── Logs ────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Deployment ──────────────────────────────────────────
.vercel

# ─── TypeScript ──────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
