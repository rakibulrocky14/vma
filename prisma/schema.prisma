generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  MANAGER
}

enum BookStatus {
  OPEN
  CLOSED
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  passwordHash      String
  role              Role           @default(MANAGER)
  villas            Villa[]
  shareholders      Shareholder[]
  incomeSources     IncomeSource[]
  linkedShareholder Shareholder?   @relation("UserShareholder")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Villa {
  id           String             @id @default(cuid())
  villaNumber  String
  address      String
  totalRooms   Int
  ownerShare   Decimal?           // manager's own % share (informational)
  ownerId      String
  owner        User               @relation(fields: [ownerId], references: [id])
  rooms        Room[]
  shareholders VillaShareholder[]
  expenses     Expense[]
  monthlyBooks MonthlyBook[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Room {
  id         String              @id @default(cuid())
  villaId    String
  roomNumber String
  villa      Villa               @relation(fields: [villaId], references: [id], onDelete: Cascade)
  records    RoomMonthlyRecord[]
  createdAt  DateTime            @default(now())
}

model Shareholder {
  id                 String                   @id @default(cuid())
  name               String
  phone              String?
  email              String?
  userId             String?                  @unique // links to a User account (for manager's own share)
  linkedUser         User?                    @relation("UserShareholder", fields: [userId], references: [id])
  createdById        String?
  createdBy          User?                    @relation(fields: [createdById], references: [id])
  villas             VillaShareholder[]
  incomeSourceShares IncomeSourceEntryShare[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
}

model VillaShareholder {
  id            String      @id @default(cuid())
  villaId       String
  shareholderId String
  percentage    Decimal
  villa         Villa       @relation(fields: [villaId], references: [id], onDelete: Cascade)
  shareholder   Shareholder @relation(fields: [shareholderId], references: [id])

  @@unique([villaId, shareholderId])
}

model MonthlyBook {
  id         String     @id @default(cuid())
  villaId    String
  year       Int
  month      Int
  status     BookStatus @default(OPEN)
  closedAt   DateTime?
  closedById String?
  villa      Villa      @relation(fields: [villaId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())

  @@unique([villaId, year, month])
}

model RoomMonthlyRecord {
  id         String  @id @default(cuid())
  roomId     String
  year       Int
  month      Int
  rentAmount Decimal @default(0)
  paidAmount Decimal @default(0)
  room       Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, year, month])
}

model Expense {
  id          String   @id @default(cuid())
  villaId     String
  year        Int
  month       Int
  description String
  amount      Decimal
  villa       Villa    @relation(fields: [villaId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Settings {
  id          String   @id @default("singleton")
  companyName String   @default("Villa Management")
  logoUrl     String?
  address     String?
  updatedAt   DateTime @updatedAt
}

// ─── Income Sources ──────────────────────────────────────────────────────────

model IncomeSource {
  id          String              @id @default(cuid())
  name        String              // person's name
  phone       String?
  notes       String?
  createdById String
  createdBy   User                @relation(fields: [createdById], references: [id])
  entries     IncomeSourceEntry[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model IncomeSourceEntry {
  id             String                   @id @default(cuid())
  incomeSourceId String
  incomeSource   IncomeSource             @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)
  propertyName   String                   // free-text villa/property name
  mySharePercent Decimal                  // user's % share (informational)
  shares         IncomeSourceEntryShare[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
}

model IncomeSourceEntryShare {
  id            String            @id @default(cuid())
  entryId       String
  entry         IncomeSourceEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  shareholderId String
  shareholder   Shareholder       @relation(fields: [shareholderId], references: [id])
  sharePercent  Decimal           // % of user's share that goes to this shareholder
  createdAt     DateTime          @default(now())

  @@unique([entryId, shareholderId])
}
