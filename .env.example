# Database (SQLite — path is inside the container; docker-compose mounts ./data here)
DATABASE_URL="file:/app/data/villa.db"

# NextAuth secret — generate one with: openssl rand -base64 32
AUTH_SECRET="change-this-to-a-random-secret"

# Full public URL of your app (no trailing slash)
NEXTAUTH_URL="https://your-domain.com"
